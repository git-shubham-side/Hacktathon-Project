<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Digital Notice Board – Authentication</title>
    <link rel="stylesheet" href="../css/index.css" />
  </head>
  <body>
    <div class="container">
      <!-- Page Title -->
      <h1>🎓 Digital Notice Board</h1>
      <p class="subtitle">
        Centralized Notification System for Educational Institutions
      </p>

      <!-- ── 4 Role Cards in a Row ── -->
      <div class="cards-row">
        <!-- Admin Card -->
        <div class="card admin">
          <div class="icon">🛡️</div>
          <h3>Admin</h3>
          <div class="btn-group">
            <a href="/signup/admin" class="btn btn-signup">Create Account</a>
            <a href="./login/admin-login.html" class="btn btn-login">Log In</a>
          </div>
        </div>

        <!-- Teacher Card -->
        <div class="card teacher">
          <div class="icon">👨‍🏫</div>
          <h3>Teacher</h3>
          <div class="btn-group">
            <a href="./signup/teacher" class="btn btn-signup">Create Account</a>
            <a href="./login/teacher-login.html" class="btn btn-login"
              >Log In</a
            >
          </div>
        </div>

        <!-- Student Card -->
        <div class="card student">
          <div class="icon">🎓</div>
          <h3>Student</h3>
          <div class="btn-group">
            <a href="/signup/student" class="btn btn-signup">Create Account</a>
            <a href="./login/student-login.html" class="btn btn-login"
              >Log In</a
            >
          </div>
        </div>

        <!-- Parent Card -->
        <div class="card parent">
          <div class="icon">👨‍👩‍👧</div>
          <h3>Parent / Guardian</h3>
          <div class="btn-group">
            <a href="/signup/parent" class="btn btn-signup">Create Account</a>
            <a href="./login/parent-login.html" class="btn btn-login">Log In</a>
          </div>
        </div>
      </div>
      <!-- End Cards Row -->

      <!-- Footer -->
      <div class="footer">
        <p style="color: black">
          A Project Created By <b><i>Node Ninjas</i></b>
        </p>
      </div>
    </div>
  </body>
</html>
